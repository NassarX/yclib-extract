# yclib-extract Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# ALGOLIA CONFIGURATION (YC Library Discovery)
# =============================================================================

# Algolia Application ID for YC Library API access
# Default: 45BWZJ1SGC (public key)
ALGOLIA_APP_ID=45BWZJ1SGC

# Algolia API Key for YC Library API access
# Default: Public analytics key (limited permissions)
# To get credentials manually:
# 1. Open https://www.ycombinator.com/library/search in Chrome
# 2. Open DevTools (F12) → Network tab → filter by "algolia"
# 3. Click any search/browse request → Headers → copy X-Algolia-API-Key
ALGOLIA_API_KEY=MDlkNDAyNzM1YjA2YTQwYjBkMGIwNjk2Mzg4NDQ3ZGRkMTdhZWJmODM0MDdiNDVhMTNlNDRiYzFlOGZiMGI5MmFuYWx5dGljc1RhZ3M9eWNkYyUyQ2xpYnJhcnkmcmVzdHJpY3RJbmRpY2VzPUxpYnJhcnlfYm9va2ZhY2VfcHJvZHVjdGlvbiZ0YWdGaWx0ZXJzPSU1QiUyMnljZGNfcHVibGljJTIyJTJDJTVCJTIya2Jfcm9vdF8xNzYlMjIlMkMlMjJrYl9yb290XzkxMiUyMiU1RCU1RA==

# Algolia Index Name for YC Library
# Default: Library_bookface_production
ALGOLIA_INDEX=Library_bookface_production

# =============================================================================
# OUTPUT DIRECTORIES
# =============================================================================

# Directory for YC Library extracted content (Markdown files)
# Default: artifacts/yc_library
CONTENT_DIR=artifacts/yc_library

# Directory for Paul Graham essays
# Default: artifacts/pg_essays
PG_ESSAYS_DIR=artifacts/pg_essays

# Directory for Sam Altman essays
# Default: artifacts/altman_essays
ALTMAN_ESSAYS_DIR=artifacts/altman_essays

# =============================================================================
# CONTENT EXTRACTION SETTINGS
# =============================================================================

# Minimum content length for extracted pages (in characters)
# Default: 2000 (production), 700 (development)
# Set lower for development to accept shorter extracted pages
YCLIB_EXTRACT_MIN_CONTENT_LENGTH=700

# =============================================================================
# YOUTUBE TRANSCRIPT SETTINGS
# =============================================================================

# Invidious instances for YouTube transcript fallback (comma-separated)
# Used when official YouTube API is blocked or unavailable
# Default: yewtu.cafe,invidio.us
INVIDIOUS_INSTANCES=yewtu.cafe,invidio.us

# YouTube transcript proxy URL (all protocols)
# Optional: Set if direct YouTube requests are blocked
YOUTUBE_PROXY_URL=

# YouTube HTTP proxy URL
# Optional: Set if direct YouTube HTTP requests are blocked
YOUTUBE_HTTP_PROXY_URL=

# YouTube HTTPS proxy URL
# Optional: Set if direct YouTube HTTPS requests are blocked
YOUTUBE_HTTPS_PROXY_URL=

# =============================================================================
# GENERAL PROXY SETTINGS (Fallback for all HTTP/HTTPS requests)
# =============================================================================

# HTTP proxy URL (used as fallback for all HTTP requests)
# Example: http://proxy.example.com:8080
HTTP_PROXY=

# HTTPS proxy URL (used as fallback for all HTTPS requests)
# Example: http://proxy.example.com:8080
HTTPS_PROXY=

# All protocols proxy URL (used as fallback if HTTP/HTTPS not set)
# Example: http://proxy.example.com:8080
ALL_PROXY=